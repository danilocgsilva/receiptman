use App\Kernel;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;

require_once './vendor/autoload.php';

$kernel = new Kernel('dev', true);
$kernel->boot();

$container = $kernel->getContainer();
$application = new Application();

// Get Symfony’s command loader
$loader = $container->get('console.command_loader');

// Manually load commands from it, but keep only those in your namespace
foreach ($loader->getNames() as $name) {
// foreach ($loader->getServiceIds as $id) {
    // print($name . PHP_EOL);
    $command = $loader->get($name);
    print(get_class($command) . PHP_EOL);

    if ($command instanceof Command && str_starts_with(get_class($command), 'App\\')) {
        $application->add($command);
        print("------------------------");
    }
}

$application->run();





